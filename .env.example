
# Base OpenAI settings
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY="..."


# -- SEARCH SETTINGS ---

# Выбрать один из трёх вариантов:

# # Вариант 1 — Tavily
# SEARCH_ENABLED=true
# SEARCH_PROVIDER=tavily
# SEARCH_API_KEY=tvly-xxxxx

# # Вариант 2 — Serper
# SEARCH_ENABLED=true
# SEARCH_PROVIDER=serper
# SEARCH_API_KEY=serper-xxxxx

# # Вариант 3 — Sonar через OpenRouter (или аналог) (самый простой, не нужен отдельный API key)
# SEARCH_ENABLED=true
# SEARCH_PROVIDER=sonar
# SEARCH_SONAR_MODEL=perplexity/sonar-pro   # или perplexity/sonar
